<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Survey Results - Analysis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="style.css" />
</head>
<body>
    <div class="survey-header">
        <div class="container">
            <h1 class="display-4 fw-bold text-white my-4">Survey Results Analysis</h1>
            <p class="lead text-white-50 mb-0">Summary of feedback on Sephora Canada's UI</p>
        </div>
    </div>

    <main class="container my-5">
        <section class="mb-5">
            <h2 class="mb-4 fw-bold">Survey Responses Overview</h2>
            <div class="charts-container">
                <div class="chart-item">
                    <h3 class="text-center mb-3">Navigation Ease</h3>
                    <div style="position: relative; height: 280px; width: 100%;">
                        <canvas id="navChart"></canvas>
                    </div>
                </div>
                <div class="chart-item">
                    <h3 class="text-center mb-3">Recommendation Likelihood</h3>
                    <div style="position: relative; height: 280px; width: 100%;">
                        <canvas id="recChart"></canvas>
                    </div>
                </div>
                <div class="chart-item">
                    <h3 class="text-center mb-3">Visual Design Rating</h3>
                    <div style="position: relative; height: 280px; width: 100%;">
                        <canvas id="visualChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-5">
            <h2 class="mb-4 fw-bold">Detailed Text Responses</h2>
            <% if(results.textResponses && results.textResponses.length > 0){ %>
                <div class="row">
                    <% results.textResponses.forEach(function(item, index){ %>
                        <div class="col-md-6 mb-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Response #<%= index + 1 %></h5>
                                    <p class="card-text">
                                        <strong class="text-primary">Like/Dislike:</strong><br>
                                        <%= item.like_dislike %>
                                    </p>
                                    <p class="card-text">
                                        <strong class="text-success">Improvement:</strong><br>
                                        <%= item.improvement %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-info" role="alert">
                    No text responses available yet.
                </div>
            <% } %>
        </section>

        <section class="mb-5">
            <div class="text-center">
                <a href="/" class="btn btn-primary btn-lg">← Back to Survey</a>
            </div>
        </section>
    </main>

    <footer class="bg-light border-top mt-5">
        <div class="container py-4 text-center text-muted">
            <p class="mb-0">
                Website designed by Group 2: Deval Chovatia, Priya Dharmendra Kumar, Darrell Nyakaana
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function createChart(id, dataObj, chartLabel){
            if(!dataObj) return;
            const colors = ['#667eea', '#764ba2', '#f093fb', '#4facfe', '#43e97b', '#fa709a', '#feca57', '#ff9ff3'];
            new Chart(document.getElementById(id), {
                type: 'doughnut',
                data: {
                    labels: Object.keys(dataObj),
                    datasets: [{
                        label: chartLabel,
                        data: Object.values(dataObj),
                        backgroundColor: colors.slice(0, Object.keys(dataObj).length),
                        borderColor: 'white',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                font: {
                                    size: 11
                                }
                            }
                        }
                    }
                }
            });
        }

        createChart('navChart', <%- JSON.stringify(results.navigation || {}) %>, 'Navigation Ease');
        createChart('recChart', <%- JSON.stringify(results.rec || {}) %>, 'Recommendation');
        createChart('visualChart', <%- JSON.stringify(results.visual || {}) %>, 'Visual Rating');
    </script>
</body>
</html>
